# Supabase — Transaction pooler (port 6543) — used by the application at runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase — Direct connection (port 5432) — used ONLY for running migrations
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
